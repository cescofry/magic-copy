{
  "manifest_version": 2,
  "name": "Magic Copy",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "magic-copy@ziofritz",
      "strict_min_version": "109.0"
    }
  },
  "description": "Smart clipboard picker on Cmd/Ctrl+C with no selection.",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
